/* ==============================
   Letter Text Styling
============================== */

#letterText {
  margin-top: 20px;
  font-size: clamp(16px, 4vw, 18px);
  line-height: 1.8;
  color: #333;
  text-align: left;
  white-space: normal;
  padding: 15px;
  border-radius: 15px;
  background: linear-gradient(145deg, #fff, #ffe6f0);
  box-shadow: 0 8px 20px rgba(0,0,0,0.15);
  animation: fadeLetter 0.8s ease forwards;
}

/* Hidden state */
#letterText.hidden {
  display: none;
}

/* Romantic fade animation */
@keyframes fadeLetter {
  from {
    opacity: 0;
    transform: translateY(15px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Image inside letter */
#letterText img {
  width: 100%;
  max-width: 250px;
  margin: 20px auto 0;
  display: block;
  border-radius: 15px;
  box-shadow: 0 8px 20px rgba(0,0,0,0.25);
  transition: 0.3s ease;
}

/* Image hover effect */
#letterText img:hover {
  transform: scale(1.05);
}
