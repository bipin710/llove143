/* ==============================
   Root Colors
============================== */
:root {
  --pink-1: #ffe6f0;
  --pink-2: #ffb3d9;
  --pink-3: #ff66b2;
  --pink-4: #ff3385;
  --ink: #fff;
  --overlay-dark: rgba(0, 0, 0, 0.5);
  --shadow-dark: rgba(0,0,0,0.6);
}

/* ==============================
   Global Reset & Base
============================== */
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}
html {
  scroll-behavior: smooth;
}
body {
  font-family: 'Poppins', sans-serif;
  color: var(--ink);
  text-align: center;
  line-height: 1.6;
  overflow-x: hidden;
  background: url('image/ngt.jpg') no-repeat center center fixed;
  background-size: cover;
  position: relative;
}

/* Dark Overlay */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  background: var(--overlay-dark);
  z-index: -1;
}

/* ==============================
   Stars & Shooting Stars
============================== */
.stars {
  position: fixed;
  inset: 0;
  z-index: -2;
  overflow: hidden;
}
.stars::after {
  content: '';
  position: absolute;
  width: 2px;
  height: 2px;
  background: white;
  box-shadow:
    20px 30px rgb(202, 50, 50), 50px 100px rgb(241, 162, 162), 80px 60px rgb(150, 97, 97),
    120px 200px rgb(148, 109, 109), 200px 300px rgb(99, 63, 63), 300px 150px white,
    400px 250px white, 500px 50px white, 600px 400px white,
    700px 200px rgb(153, 2, 2), 800px 350px rgb(116, 61, 61), 900px 150px rgb(124, 38, 38),
    1000px 300px rgb(75, 45, 45);
  animation: twinkle 2s infinite alternate;
}
@keyframes twinkle {
  from {opacity:0.5;}
  to {opacity:1;}
}
.shooting-star {
  position: fixed;
  width: 100%;
  height: 100%;
  background: transparent;
  z-index: -1;
  pointer-events: none;
}
.shooting-star::after {
  content: '';
  position: absolute;
  width: 2px;
  height: 2px;
  background: white;
  box-shadow: 
    50px 80px white, 150px 120px white, 250px 200px white,
    350px 50px white, 450px 300px white, 550px 180px white,
    650px 400px white, 750px 100px white, 850px 250px white;
  animation: shoot 3s infinite linear;
}
@keyframes shoot {
  0% { transform: translate(0,0) rotate(45deg); opacity: 0; }
  10% { opacity: 1; }
  100% { transform: translate(1200px, 800px) rotate(45deg); opacity: 0; }
}

/* ==============================
   Header
============================== */
header {
  position: sticky;
  top: 0;
  z-index: 100;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 20px;
  backdrop-filter: blur(12px);
  background: rgba(0,0,0,0.6);
}
.brand {
  font-family: 'Great Vibes', cursive;
  font-size: clamp(20px, 4vw, 30px);
  color: var(--pink-4);
  text-shadow: 1px 1px 6px var(--shadow-dark);
}
.controls {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
}
.btn {
  padding: 8px 16px;
  border-radius: 30px;
  border: none;
  cursor: pointer;
  font-size: 14px;
  background: var(--pink-3);
  color: rgb(95, 78, 78);
  transition: 0.3s ease;
  text-shadow: 1px 1px 3px var(--shadow-dark);
}
.btn:hover { transform: scale(1.05); }
.btn.secondary { background: rgba(255,255,255,0.8); color: var(--pink-4); }

/* ==============================
   Proposal Section
============================== */
.proposal { padding: 60px 20px 30px; }
.proposal h2 {
  font-family: 'Great Vibes', cursive;
  font-size: clamp(24px, 6vw, 38px);
  margin-bottom: 20px;
  color: #ceb7b7;
  text-shadow: 2px 2px 10px var(--shadow-dark);
}
.buttons button {
  padding: 14px 30px;
  margin: 10px;
  border-radius: 30px;
  border: none;
  cursor: pointer;
  font-size: 16px;
  transition: 0.3s;
}
#yesBtn { background: var(--pink-4); color: rgb(90, 9, 241); }
#noBtn { background: #444; color: white; }
.buttons button:hover { transform: scale(1.1); }

/* ==============================
   Secret Letter Popup
============================== */
.letter-popup {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.85);
  justify-content: center;
  align-items: center;
  z-index: 1000;
  padding: 20px;
  transition: opacity 0.3s ease;
}
.letter-popup.active { display: flex; animation: fadeIn 0.4s ease forwards; }
@keyframes fadeIn { from { opacity: 0; transform: scale(0.95); } to { opacity: 1; transform: scale(1); } }
.letter-box {
  background: rgba(255,255,255,0.95);
  padding: 30px 25px;
  border-radius: 20px;
  width: 90%;
  max-width: 400px;
  text-align: center;
  color: #222;
  box-shadow: 0 10px 30px rgba(0,0,0,0.4);
}
.letter-box h3 {
  font-family: 'Great Vibes', cursive;
  font-size: clamp(20px, 5vw, 28px);
  color: var(--pink-4);
  margin-bottom: 20px;
  text-shadow: 1px 1px 5px var(--shadow-dark);
}
.letter-box input {
  width: 100%;
  padding: 12px 15px;
  margin-bottom: 15px;
  border-radius: 10px;
  border: 1px solid #ccc;
  font-size: 16px;
  outline: none;
  transition: 0.3s;
}
.letter-box input:focus {
  border-color: var(--pink-3);
  box-shadow: 0 0 8px var(--pink-2);
}
.letter-box button {
  padding: 12px 25px;
  margin: 5px;
  border-radius: 30px;
  border: none;
  cursor: pointer;
  font-size: 16px;
  transition: 0.3s ease;
  background: var(--pink-4);
  color: white;
  box-shadow: 1px 1px 6px var(--shadow-dark);
}
