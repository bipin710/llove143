/* ==============================
   3D Gallery
============================== */
.gallery-section { display: none; margin: 60px auto; perspective: 1000px; }
.gallery {
  width: clamp(200px, 60vw, 300px);
  height: clamp(200px, 60vw, 300px);
  margin: auto;
  position: relative;
  transform-style: preserve-3d;
  animation: rotate 20s linear infinite;
}
.gallery img {
  position: absolute;
  width: 80%;
  height: 80%;
  left: 50%;
  top: 50%;
  transform-style: preserve-3d;
  border-radius: 15px;
  object-fit: cover;
  box-shadow: 0 8px 20px rgba(0,0,0,0.3);
}
.gallery img:nth-child(0){transform:translate(-50%,-50%) rotateY(0deg) translateZ(280px);}
.gallery img:nth-child(1){transform:translate(-50%,-50%) rotateY(0deg) translateZ(280px);}
.gallery img:nth-child(2){transform:translate(-50%,-50%) rotateY(45deg) translateZ(280px);}
.gallery img:nth-child(3){transform:translate(-50%,-50%) rotateY(90deg) translateZ(280px);}
.gallery img:nth-child(4){transform:translate(-50%,-50%) rotateY(135deg) translateZ(280px);}
.gallery img:nth-child(5){transform:translate(-50%,-50%) rotateY(180deg) translateZ(280px);}
.gallery img:nth-child(6){transform:translate(-50%,-50%) rotateY(225deg) translateZ(280px);}
.gallery img:nth-child(7){transform:translate(-50%,-50%) rotateY(270deg) translateZ(280px);}
.gallery img:nth-child(8){transform:translate(-50%,-50%) rotateY(315deg) translateZ(280px);}
@keyframes rotate { from{transform:rotateY(0deg);} to{transform:rotateY(360deg);} }

